{
    "name": "tashgheel-pos",
    "version": "1.0.2",
    "description": "Tashgheel Online POS",
    "main": "server/index.js",
    "scripts": {
        "start": "prisma db push --accept-data-loss && node server/index.js",
        "dev": "nodemon server/index.js",
        "postinstall": "prisma generate",
        "db:generate": "prisma generate",
        "db:push": "prisma db push",
        "db:migrate": "prisma migrate dev",
        "db:studio": "prisma studio",
        "tw:build": "node node_modules/tailwindcss/lib/cli.js -i ./css/tailwind.input.css -o ./css/tailwind.css --minify",
        "build": "node node_modules/tailwindcss/lib/cli.js -i ./css/tailwind.input.css -o ./css/tailwind.css --minify"
    },
    "dependencies": {
        "@prisma/client": "^6.19.3",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "jsonwebtoken": "^9.0.2",
        "nodemailer": "^6.9.7",
        "prisma": "^6.19.3"
    },
    "devDependencies": {
        "nodemon": "^3.0.1",
        "tailwindcss": "^3.4.19"
    },
    "engines": {
        "node": ">=18.x"
    }
}
